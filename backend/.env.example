# ============================================
# Authentication & Security
# ============================================
JWT_SECRET_KEY=change-this-to-your-secret-key-in-production
JWT_EXPIRY_HOURS=24

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/sentra_terminal
# For development, use SQLite:
# DATABASE_URL=sqlite:///./sentra.db

# ============================================
# Pacifica Trading Network
# ============================================
# Pacifica API Configuration - Uses Solana keypair signing
PACIFICA_API_BASE_URL=https://api.pacifica.fi/api/v1
# Base58-encoded Solana private key for signing requests
PACIFICA_PRIVATE_KEY=your_base58_solana_private_key_here
# Optional: builder code for referral attribution
PACIFICA_BUILDER_CODE=your_pacifica_builder_code_here

# ============================================
# Elfa Social Data API
# ============================================
ELFA_API_KEY=your_elfa_api_key
ELFA_API_BASE_URL=https://api.elfa.ai
ELFA_API_TIMEOUT=10

# ============================================
# Price Data Feeds
# ============================================
# Coingecko (free, no key required)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT=10

# CoinMarketCap (requires API key)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
COINMARKETCAP_API_URL=https://pro-api.coinmarketcap.com/v1

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# ============================================
# WebSocket Configuration
# ============================================
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ============================================
# Data Update Intervals (seconds)
# ============================================
PRICE_UPDATE_INTERVAL=5
SENTIMENT_UPDATE_INTERVAL=30
LIQUIDATION_UPDATE_INTERVAL=10
WHALE_UPDATE_INTERVAL=15
TRADER_SCORE_UPDATE_INTERVAL=60
